# Database
DATABASE_URL=postgresql://user:password@localhost:5432/onoma

# JWT
SECRET_KEY=change-me-to-a-random-32-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Super admin (protege endpoints de /admin)
SUPER_ADMIN_TOKEN=change-me

# CORS — origens permitidas (separadas por vírgula)
# Exemplo produção: CORS_ORIGINS=["https://app.onoma.com.br"]
CORS_ORIGINS=["http://localhost:3000"]

# INPI RPI
RPI_BASE_URL=https://revistas.inpi.gov.br/txt
RPI_SCHEDULE_DAY_OF_WEEK=tue
RPI_SCHEDULE_HOUR=10
